<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="24dp">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="选择更新方式" android:textSize="24sp" android:textColor="#333333" android:textStyle="bold" android:layout_marginBottom="16dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="请选择更新方式:" android:textSize="14sp" android:textColor="#666666" android:layout_marginBottom="16dp"/>
    <LinearLayout android:id="@+id/btn_in_app" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#F5F5F0" android:padding="16dp" android:layout_marginBottom="8dp" android:clickable="true" android:focusable="true">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="软件内更新" android:textSize="16sp" android:textColor="#333333" android:textStyle="bold"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="在应用内下载 APK，完成后自动拉起安装" android:textSize="12sp" android:textColor="#888888" android:layout_marginTop="4dp"/>
    </LinearLayout>
    <LinearLayout android:id="@+id/btn_browser" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#F5F5F0" android:padding="16dp" android:layout_marginBottom="16dp" android:clickable="true" android:focusable="true">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="浏览器更新" android:textSize="16sp" android:textColor="#333333" android:textStyle="bold"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="跳转浏览器下载（与原流程一致）" android:textSize="12sp" android:textColor="#888888" android:layout_marginTop="4dp"/>
    </LinearLayout>
    <Button android:id="@+id/btn_cancel" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="取消" android:background="#F5F5F0" android:textColor="#888888"/>
</LinearLayout>
